{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/accordion",
	"version": "1.0.0",
	"title": "Accordion",
	"category": "goblocks",
	"description": "Collapsible content panels using native <details>/<summary>. Supports FAQ schema and single-open mode.",
	"keywords": [ "accordion", "collapse", "faq", "details", "summary" ],
	"textdomain": "goblocks",
	"supports": {
		"html": false,
		"customClassName": false,
		"className": false,
		"anchor": false
	},
	"attributes": {
		"uniqueId": {
			"type": "string",
			"default": ""
		},
		"tagName": {
			"type": "string",
			"default": "div"
		},
		"styles": {
			"type": "object",
			"default": {}
		},
		"globalClasses": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"default": []
		},
		"htmlAttributes": {
			"type": "object",
			"default": {}
		},
		"dynamicContent": {
			"type": "object",
			"default": {}
		},
		"generatedCss": {
			"type": "string",
			"default": ""
		},
		"blockVersion": {
			"type": "integer",
			"default": 1
		},
		"enableFaqSchema": {
			"type": "boolean",
			"default": false
		},
		"allowMultiple": {
			"type": "boolean",
			"default": true
		}
	},
	"providesContext": {
		"goblocks/accordionFaqSchema": "enableFaqSchema"
	},
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js"
}
