{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/star-rating",
	"version": "1.0.0",
	"title": "Star Rating",
	"category": "goblocks",
	"description": "Display a star rating with configurable value and max stars.",
	"keywords": [ "rating", "stars", "review", "score" ],
	"textdomain": "goblocks",
	"supports": {
		"html": false,
		"customClassName": false,
		"className": false,
		"anchor": false
	},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"rating": { "type": "number", "default": 4.5 },
		"maxRating": { "type": "integer", "default": 5 },
		"showNumber": { "type": "boolean", "default": true },
		"label": { "type": "string", "default": "" },
		"starColor": { "type": "string", "default": "#f59e0b" },
		"emptyColor": { "type": "string", "default": "#d1d5db" },
		"starSize": { "type": "integer", "default": 22 },
		"reviewCount": { "type": "integer", "default": 1 },
		"showCount": { "type": "boolean", "default": false },
		"schemaEnabled": { "type": "boolean", "default": true },
		"itemName": { "type": "string", "default": "" },
		"animateOnScroll": { "type": "boolean", "default": true },
		"styles": { "type": "object", "default": {} },
		"globalClasses": {
			"type": "array",
			"items": { "type": "string" },
			"default": []
		},
		"generatedCss": { "type": "string", "default": "" },
		"blockVersion": { "type": "integer", "default": 1 }
	},
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js"
}
