{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/counter",
	"version": "1.0.0",
	"title": "Counter",
	"category": "goblocks",
	"description": "Animated number counter that counts up when scrolled into view.",
	"keywords": [ "counter", "number", "count", "animate", "statistic" ],
	"textdomain": "goblocks",
	"supports": {
		"html": false,
		"customClassName": false,
		"className": false,
		"anchor": false
	},
	"attributes": {
		"uniqueId": { "type": "string", "default": "" },
		"target": { "type": "number", "default": 100 },
		"prefix": { "type": "string", "default": "" },
		"suffix": { "type": "string", "default": "" },
		"label": { "type": "string", "default": "" },
		"startFrom": { "type": "number", "default": 0 },
		"duration": { "type": "number", "default": 2000 },
		"easing": { "type": "string", "default": "ease-out" },
		"countDown": { "type": "boolean", "default": false },
		"separator": { "type": "string", "default": "" },
		"decimals": { "type": "integer", "default": 0 },
		"numberColor": { "type": "string", "default": "#4f46e5" },
		"labelColor": { "type": "string", "default": "#9ca3af" },
		"styles": { "type": "object", "default": {} },
		"globalClasses": {
			"type": "array",
			"items": { "type": "string" },
			"default": []
		},
		"generatedCss": { "type": "string", "default": "" },
		"blockVersion": { "type": "integer", "default": 1 }
	},
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js"
}
