{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/pricing",
	"version": "1.0.0",
	"title": "Pricing Card",
	"category": "goblocks",
	"description": "A pricing card with plan name, price, features list and CTA button.",
	"keywords": [ "pricing", "price", "plan", "subscription" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":      { "type": "string",  "default": "" },
		"planName":      { "type": "string",  "default": "Pro Plan" },
		"price":         { "type": "string",  "default": "29" },
		"period":        { "type": "string",  "default": "/month" },
		"currency":      { "type": "string",  "default": "$" },
		"description":   { "type": "string",  "default": "Everything you need to get started." },
		"features":      { "type": "array",   "items": { "type": "string" }, "default": ["Feature one","Feature two","Feature three"] },
		"ctaText":       { "type": "string",  "default": "Get Started" },
		"ctaUrl":        { "type": "string",  "default": "#" },
		"featured":      { "type": "boolean", "default": false },
		"featuredLabel": { "type": "string",  "default": "Most Popular" },
		"accentColor":   { "type": "string",  "default": "#4f46e5" },
		"btnTextColor":  { "type": "string",  "default": "#ffffff" },
		"headingColor":  { "type": "string",  "default": "#0f172a" },
		"textColor":     { "type": "string",  "default": "#374151" },
		"checkColor":    { "type": "string",  "default": "#059669" },
		"cardBg":        { "type": "string",  "default": "#ffffff" },
		"priceAlt":      { "type": "string",  "default": "" },
		"periodAlt":     { "type": "string",  "default": "/yr" },
		"savingsLabel":    { "type": "string",  "default": "" },
		"animateOnScroll": { "type": "boolean", "default": true },
		"styles":          { "type": "object",  "default": {} },
		"globalClasses": { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":  { "type": "string",  "default": "" },
		"blockVersion":  { "type": "integer", "default": 1 }
	},
	"editorScript": "file:./index.js",
	"viewScript":   "file:./view.js"
}