{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/navigation",
	"version": "1.0.0",
	"title": "Navigation",
	"category": "goblocks",
	"description": "Render a WordPress navigation menu with mobile hamburger toggle.",
	"keywords": [ "navigation", "menu", "nav", "header" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":           { "type": "string",  "default": "" },
		"menuId":             { "type": "integer", "default": 0 },
		"layout":             { "type": "string",  "default": "horizontal" },
		"mobileBreakpoint":   { "type": "string",  "default": "768px" },
		"showMobileToggle":   { "type": "boolean", "default": true },
		"sticky":             { "type": "boolean", "default": false },
		"scrollHide":         { "type": "boolean", "default": false },
		"linkColor":          { "type": "string",  "default": "" },
		"hoverColor":         { "type": "string",  "default": "" },
		"activeColor":        { "type": "string",  "default": "" },
		"dropdownBg":         { "type": "string",  "default": "" },
		"styles":             { "type": "object",  "default": {} },
		"globalClasses":      { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":       { "type": "string",  "default": "" },
		"blockVersion":       { "type": "integer", "default": 1 }
	},
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js"
}
