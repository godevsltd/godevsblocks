{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/modal",
	"version": "1.0.0",
	"title": "Modal",
	"category": "goblocks",
	"description": "A modal/popup dialog triggered by a button or link.",
	"keywords": [ "modal", "popup", "overlay", "dialog" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":        { "type": "string",  "default": "" },
		"triggerText":     { "type": "string",  "default": "Open Modal" },
		"triggerType":     { "type": "string",  "default": "button" },
		"closeOnOverlay":  { "type": "boolean", "default": true },
		"closeOnEscape":   { "type": "boolean", "default": true },
		"animation":       { "type": "string",  "default": "fade" },
		"autoOpen":        { "type": "boolean", "default": false },
		"autoOpenDelay":   { "type": "integer", "default": 2000 },
		"cookieName":      { "type": "string",  "default": "" },
		"cookieDays":      { "type": "integer", "default": 30 },
		"showDismissBtn":  { "type": "boolean", "default": false },
		"styles":          { "type": "object",  "default": {} },
		"globalClasses":   { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":    { "type": "string",  "default": "" },
		"blockVersion":    { "type": "integer", "default": 1 }
	},
	"viewScript":   "file:./view.js",
	"editorScript": "file:./index.js"
}