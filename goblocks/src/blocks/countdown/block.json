{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/countdown",
	"version": "1.0.0",
	"title": "Countdown",
	"category": "goblocks",
	"description": "Live countdown timer to a target date with days, hours, minutes, and seconds.",
	"keywords": [ "countdown", "timer", "deadline", "date" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":      { "type": "string",  "default": "" },
		"targetDate":    { "type": "string",  "default": "" },
		"showDays":      { "type": "boolean", "default": true },
		"showHours":     { "type": "boolean", "default": true },
		"showMinutes":   { "type": "boolean", "default": true },
		"showSeconds":   { "type": "boolean", "default": true },
		"timezone":      { "type": "string",  "default": "" },
		"countdownStyle": { "type": "string", "default": "card" },
		"showSeparator": { "type": "boolean", "default": false },
		"expiredText":   { "type": "string",  "default": "Time's up!" },
		"expiredAction": { "type": "string",  "default": "message" },
		"expiredUrl":    { "type": "string",  "default": "" },
		"numberColor":   { "type": "string",  "default": "#4f46e5" },
		"labelColor":    { "type": "string",  "default": "#9ca3af" },
		"unitBg":        { "type": "string",  "default": "#ffffff" },
		"unitBorder":    { "type": "string",  "default": "#e2e8f0" },
		"styles":        { "type": "object",  "default": {} },
		"globalClasses": { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":  { "type": "string",  "default": "" },
		"blockVersion":  { "type": "integer", "default": 1 }
	},
	"viewScript": "file:./view.js",
	"editorScript": "file:./index.js"
}
