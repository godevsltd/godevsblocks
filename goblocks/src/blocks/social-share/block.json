{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/social-share",
	"version": "1.0.0",
	"title": "Social Share",
	"category": "goblocks",
	"description": "Social sharing buttons for Facebook, Twitter, LinkedIn, WhatsApp and more.",
	"keywords": [ "share", "social", "facebook", "twitter", "linkedin" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":      { "type": "string",  "default": "" },
		"platforms":     { "type": "array",   "items": { "type": "string" }, "default": ["facebook","twitter","linkedin","whatsapp"] },
		"showLabels":    { "type": "boolean", "default": false },
		"size":          { "type": "string",  "default": "md" },
		"layout":        { "type": "string",  "default": "horizontal" },
		"buttonStyle":   { "type": "string",  "default": "filled" },
		"customUrl":     { "type": "string",  "default": "" },
		"styles":        { "type": "object",  "default": {} },
		"globalClasses": { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":  { "type": "string",  "default": "" },
		"blockVersion":  { "type": "integer", "default": 1 }
	},
	"viewScript":   "file:./view.js",
	"editorScript": "file:./index.js"
}