{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/timeline",
	"version": "1.0.0",
	"title": "Timeline",
	"category": "goblocks",
	"description": "A vertical or horizontal timeline with date/title/content items.",
	"keywords": [ "timeline", "steps", "history", "process" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":           { "type": "string",  "default": "" },
		"layout":             { "type": "string",  "default": "vertical" },
		"alternating":        { "type": "boolean", "default": false },
		"lineColor":          { "type": "string",  "default": "#4f46e5" },
		"entranceAnimation":  { "type": "string",  "default": "fade-up" },
		"styles":             { "type": "object",  "default": {} },
		"globalClasses":      { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":       { "type": "string",  "default": "" },
		"blockVersion":       { "type": "integer", "default": 1 }
	},
	"viewScript":   "file:./view.js",
	"editorScript": "file:./index.js"
}