{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/table-of-contents",
	"version": "1.0.0",
	"title": "Table of Contents",
	"category": "goblocks",
	"description": "Auto-generated table of contents from post headings.",
	"keywords": [ "toc", "table of contents", "navigation", "headings", "outline" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"attributes": {
		"uniqueId":       { "type": "string",  "default": "" },
		"title":          { "type": "string",  "default": "Table of Contents" },
		"headings":       { "type": "array",   "items": { "type": "string" }, "default": ["h2","h3"] },
		"collapsible":    { "type": "boolean", "default": false },
		"startCollapsed": { "type": "boolean", "default": false },
		"smoothScroll":   { "type": "boolean", "default": true },
		"scrollOffset":   { "type": "number",  "default": 80 },
		"listStyle":      { "type": "string",  "default": "ordered" },
		"showBackToTop":  { "type": "boolean", "default": false },
		"linkColor":      { "type": "string",  "default": "" },
		"activeColor":    { "type": "string",  "default": "" },
		"styles":         { "type": "object",  "default": {} },
		"globalClasses":  { "type": "array",   "items": { "type": "string" }, "default": [] },
		"generatedCss":   { "type": "string",  "default": "" },
		"blockVersion":   { "type": "integer", "default": 1 }
	},
	"viewScript":   "file:./view.js",
	"editorScript": "file:./index.js"
}