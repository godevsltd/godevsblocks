<?xml version="1.0"?>
<ruleset
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    name="GoBlocks"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd"
>
    <description>WordPress Coding Standards ruleset for the GoBlocks plugin.</description>

    <!-- ── Files to check ─────────────────────────────────────────────────── -->
    <file>goblocks.php</file>
    <file>uninstall.php</file>
    <file>includes/</file>

    <!-- ── Exclusions ─────────────────────────────────────────────────────── -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <!-- Development utility scripts — not loaded by WordPress, CLI output only -->
    <exclude-pattern>*/bin/*</exclude-pattern>
    <!-- Pattern files are hybrid PHP+HTML with a necessary closing ?> tag -->
    <exclude-pattern>*/patterns/*</exclude-pattern>

    <!-- ── Standards ──────────────────────────────────────────────────────── -->
    <rule ref="WordPress-Core">
        <!-- PSR-4 class files may differ from WP class-{name}.php convention -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
    </rule>
    <rule ref="WordPress-Extra" />
    <!-- WordPress-Docs excluded: enforces file/function/param docblocks beyond
         WP.org Plugin Check requirements and generates excessive noise. -->

    <!-- ── Text domain enforcement ────────────────────────────────────────── -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="goblocks" />
            </property>
        </properties>
    </rule>

    <!-- ── Global prefix enforcement ─────────────────────────────────────── -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="goblocks" />
                <element value="GoBlocks" />
                <element value="GOBLOCKS" />
            </property>
        </properties>
    </rule>

    <!-- ── Minimum WP version ─────────────────────────────────────────────── -->
    <config name="minimum_supported_wp_version" value="6.5" />

    <!-- ── PHP compatibility range ────────────────────────────────────────── -->
    <config name="testVersion" value="7.4-" />

    <!-- ── PHP file formatting ────────────────────────────────────────────── -->
    <rule ref="Generic.PHP.DisallowShortOpenTag" />
    <rule ref="Squiz.PHP.CommentedOutCode" />

    <!-- ── Tab indentation (WP standard) ─────────────────────────────────── -->
    <rule ref="Generic.WhiteSpace.DisallowTabIndent">
        <severity>0</severity>
    </rule>

</ruleset>
